# Dependencies — reinstalled inside the image from the lockfile.
node_modules
.pnp
.pnp.*

# Build output — regenerated by `next build` in the image.
.next
out
build

# Caches
.swc
coverage
*.tsbuildinfo

# Env files — secrets stay out of the image; pass values at build/run time.
.env
.env.*
!.env.example

# Local tooling / VCS / editor cruft
.git
.gitignore
.github
.vscode
.idea
.claude
.vercel
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# Docker files themselves
Dockerfile
.dockerignore
docker-compose*.yml

# Docs
README.md
