NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# Optional. Origin of the S3 bucket that serves message attachments/media.
# Only set this if media lives somewhere other than the default bucket
# (https://inhouse-panels.s3.ap-south-1.amazonaws.com). It's used solely to
# whitelist that origin in the Content-Security-Policy, not to build URLs.
# NEXT_PUBLIC_MEDIA_BASE_URL=https://your-bucket.s3.region.amazonaws.com
